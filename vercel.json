{
  "buildCommand": "hugo --gc --minify",
  "outputDirectory": "public",
  "framework": "hugo",
  "trailingSlash": true,
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/main.min.(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/post", "destination": "/", "permanent": true },
    { "source": "/post/", "destination": "/", "permanent": true },
    { "source": "/post/page/:path*", "destination": "/", "permanent": true },
    { "source": "/post/index.xml", "destination": "/", "permanent": true },
    { "source": "/halaman", "destination": "/", "permanent": true },
    { "source": "/halaman/", "destination": "/", "permanent": true },
    { "source": "/halaman/index.xml", "destination": "/", "permanent": true },
    { "source": "/genre", "destination": "/", "permanent": true },
    { "source": "/genre/", "destination": "/", "permanent": true },
    { "source": "/genre/index.xml", "destination": "/", "permanent": true },
    { "source": "/genre/-", "destination": "/", "permanent": true },
    { "source": "/genre/-/", "destination": "/", "permanent": true },
    { "source": "/genre/-/index.xml", "destination": "/", "permanent": true },
    { "source": "/studio", "destination": "/", "permanent": true },
    { "source": "/studio/", "destination": "/", "permanent": true },
    { "source": "/studio/index.xml", "destination": "/", "permanent": true },
    { "source": "/studio/-", "destination": "/", "permanent": true },
    { "source": "/studio/-/", "destination": "/", "permanent": true },
    { "source": "/studio/-/index.xml", "destination": "/", "permanent": true },
    { "source": "/season", "destination": "/", "permanent": true },
    { "source": "/season/", "destination": "/", "permanent": true },
    { "source": "/season/index.xml", "destination": "/", "permanent": true },
    { "source": "/season/-", "destination": "/", "permanent": true },
    { "source": "/season/-/", "destination": "/", "permanent": true },
    { "source": "/season/-/index.xml", "destination": "/", "permanent": true },
    { "source": "/season/2d-animation", "destination": "/", "permanent": true },
    { "source": "/season/2d-animation/", "destination": "/", "permanent": true },
    { "source": "/season/2d-animation/index.xml", "destination": "/", "permanent": true },
    { "source": "/season/3d-animation", "destination": "/", "permanent": true },
    { "source": "/season/3d-animation/", "destination": "/", "permanent": true },
    { "source": "/season/3d-animation/index.xml", "destination": "/", "permanent": true },
    {
      "source": "/prince,dont-do-this/",
      "destination": "/prince-dont-do-this/",
      "permanent": true
    },
    {
      "source": "/tales-of-demons-of-gods-season-4/",
      "destination": "/tales-of-demons-and-gods-season-4/",
      "permanent": true
    },
    {
      "source": "/tales-of-demons-of-gods-season-5-dan-6/",
      "destination": "/tales-of-demons-and-gods-season-5-dan-6/",
      "permanent": true
    },
    {
      "source": "/tales-of-demons-of-gods-season-7/",
      "destination": "/tales-of-demons-and-gods-season-7/",
      "permanent": true
    }
  ]
}
