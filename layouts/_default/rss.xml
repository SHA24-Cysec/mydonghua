{{- printf "<?xml version=\"1.0\" encoding=\"UTF-8\" ?>" | safeHTML }}
<rss version="2.0">
    <channel>
        <title>{{ .Site.Title }}</title>
        <link>{{ .Site.BaseURL }}</link>
        <description>{{ .Site.Params.deskripsi }}</description>
        <language>{{ .Site.Language.Lang }}</language>
        <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 MST" }}</lastBuildDate>

        {{ range where .Site.RegularPages "Layout" "postingan-donghua" }}
        <item>
            <title>{{ .Title }}</title>
            <link>{{ .Permalink }}</link>
            <description>{{ .Params.sinopsis }}</description>
            <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 MST" }}</pubDate>
            <guid>{{ .Permalink }}</guid>
            <enclosure url='{{ absURL .Params.thumbnail }}' type="image/webp" length="12345678"></enclosure>
        </item>
        {{ end }}
    </channel>
</rss>